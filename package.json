{
  "name": "obsidian-ai-quiz-plugin",
  "version": "1.0.0",
  "description": "GenQuiZ – AI-powered quiz generator & loader for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "webpack --mode=development --watch",
    "build": "webpack --mode=production",
    "lint": "eslint src",
    "pretty": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "obsidian",
    "quiz",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dompurify": "^3.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "builtin-modules": "^3.3.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.7",
    "obsidian": "latest",
    "prettier": "^3.3.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,css,md}": [
      "prettier --write"
    ],
    "*.{js,ts,tsx}": [
